{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "func",
      "label": "func: host start",
      "command": "host start",
      "problemMatcher": "$func-dotnet-watch",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/FunctionApp"
      },
      "dependsOn": "build"
    },
    {
      "label": "build",
      "command": "dotnet",
      "type": "shell",
      "args": [ "build", "${workspaceFolder}/FunctionApp/FunctionApp.csproj" ],
      "group": "build",
      "problemMatcher": "$msCompile"
    }
  ]
}
